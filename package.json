{
  "scripts": {
    "backend": "npm --prefix backend run dev",
    "frontend": "npm --prefix frontend start",
    "pcfrontend": "cd ./frontend && npm run startpc",
    "dev": "concurrently \"npm run backend\" \"npm run frontend\"",
    "start": "concurrently \"npm run backend\" \"npm run pcfrontend\""
  },
  "devDependencies": {
    "@types/react-router-dom": "^5.3.3",
    "concurrently": "^9.2.1"
  },
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^7.13.1"
  }
}
